# ─── Rust ──────────────────────────────────────────────────────
rust-imgproc/target/
dpf/target/
vendor/glyphweaveforge/target/

# ─── Test fixtures (large media files - download with script) ────
dpf/test_fixtures/*.mp4
dpf/test_fixtures/*.mp3
dpf/test_fixtures/*.wav
dpf/test_fixtures/*.ogg
dpf/test_fixtures/*.webm
dpf/test_fixtures/*.m4a
dpf/test_fixtures/*.aac
dpf/test_fixtures/*.flac
# But keep the README
!dpf/test_fixtures/README.md
# Keep corrupt/ directory structure for error testing
!dpf/test_fixtures/corrupt/

# ─── Go ────────────────────────────────────────────────────────
# Binarios compilados
dpf-example
go-bridge/example/dpf-example

# ─── Binario Rust (symlink en raíz, generado por make build) ───
dpf
!/dpf 
# ─── Salida de ejemplos y pruebas ───────────────────────────────
output/

.atl/

# ─── Imágenes de ejemplo / assets de prueba ─────────────────────
# Mantener assets/ con SVGs de diseño pero ignorar raster de prueba
assets/*.png
assets/*.jpg
assets/*.jpeg
assets/*.webp
# No ignorar los SVGs (son fuente de diseño, valen la pena versionar)
!assets/*.svg

# Imágenes de prueba en la raíz
*.png
*.jpg
*.jpeg
*.webp
*.ico

!devpixelforge.png
# Excepto si forman parte del proyecto (ej. README)
!docs/**/*.png

# ─── PDFs generados ─────────────────────────────────────────────
*.pdf
!docs/validation/markdown-to-pdf/*.pdf

